<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Identity -->
    <key>CFBundleName</key>
    <string>zurm</string>
    <key>CFBundleDisplayName</key>
    <string>zurm</string>
    <key>CFBundleIdentifier</key>
    <string>com.studiowebux.zurm</string>
    <key>CFBundleVersion</key>
    <string>__BUILD__</string>
    <key>CFBundleShortVersionString</key>
    <string>__VERSION__</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>zurm</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- Icon -->
    <key>CFBundleIconFile</key>
    <string>zurm</string>
    <key>CFBundleIconName</key>
    <string>zurm</string>

    <!-- Display -->
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSSupportsAutomaticGraphicsSwitching</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <!-- macOS version -->
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>

    <!-- Category -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.developer-tools</string>

    <!-- Architecture -->
    <key>LSArchitecturePriority</key>
    <array>
        <string>arm64</string>
    </array>

    <!-- Appearance -->
    <key>NSAppearance</key>
    <string>NSAppearanceNameDarkAqua</string>
    <key>NSRequiresAquaSystemAppearance</key>
    <false/>

    <!-- Multiple instances -->
    <key>LSMultipleInstancesProhibited</key>
    <false/>

    <!-- Dock & window behavior -->
    <key>LSUIElement</key>
    <false/>
    <key>NSSupportsSuddenTermination</key>
    <false/>

    <!-- Privacy descriptions (required for TCC / notarization) -->
    <key>NSAppleEventsUsageDescription</key>
    <string>zurm needs to send Apple Events to open URLs in your default browser.</string>
    <key>NSDocumentsFolderUsageDescription</key>
    <string>zurm needs access to Documents to open terminals and browse files in this folder.</string>
    <key>NSDesktopFolderUsageDescription</key>
    <string>zurm needs access to Desktop to open terminals, browse files, and save recordings in this folder.</string>
    <key>NSDownloadsFolderUsageDescription</key>
    <string>zurm needs access to Downloads to open terminals and browse files in this folder.</string>
    <key>NSRemovableVolumesUsageDescription</key>
    <string>zurm needs access to removable volumes to open terminals and browse files on external drives.</string>
    <key>NSNetworkVolumesUsageDescription</key>
    <string>zurm needs access to network volumes to open terminals and browse files on network drives.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>zurm needs microphone access to transcribe spoken input into the terminal.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>zurm uses on-device speech recognition to convert voice to terminal input. Audio never leaves your Mac.</string>

    <!-- Open With: register as an Alternate handler for folders -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.folder</string>
            </array>
        </dict>
    </array>

    <!-- Copyright -->
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Studio Webux. MIT License.</string>
</dict>
</plist>
